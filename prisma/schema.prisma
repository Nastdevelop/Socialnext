generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  bio       String?
  image     String?
  password  String
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())

  posts      Post[]
  otp        Otp?
  likes      Like[]
  comment    Comment[]
  savedPosts SavedPost[]
  reports    Report[]

  sentFriends     Friend[] @relation("peminta")
  receivedFriends Friend[] @relation("penerima")

  sentMessages     Message[] @relation("Sender")
  receivedMessages Message[] @relation("Receiver")

  blockedUsers Block[] @relation("blocker")
  blockedBy    Block[] @relation("blocked")
}

model Post {
  id          Int      @id @default(autoincrement())
  content     String
  dokumentasi String?
  edited      Boolean  @default(false)
  createdAt   DateTime @default(now())

  likes   Like[]
  comment Comment[]
  savedBy SavedPost[]
  reports Report[]

  authorId Int
  author   User @relation(fields: [authorId], references: [id])
}

model Friend {
  id         Int          @id @default(autoincrement())
  idpeminta  Int
  idpenerima Int
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  peminta  User @relation("peminta", fields: [idpeminta], references: [id])
  penerima User @relation("penerima", fields: [idpenerima], references: [id])

  @@unique([idpeminta, idpenerima])
}

model Comment {
  id        Int      @id @default(autoincrement())
  komentar  String
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

enum Status {
  PENDING
  ACTIVE
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Otp {
  id        Int      @id @default(autoincrement())
  code      String
  expiredAt DateTime
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
}

model SavedPost {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("Sender", fields: [senderId], references: [id])
  receiver User @relation("Receiver", fields: [receiverId], references: [id])
}

model Block {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())

  blocker User @relation("blocker", fields: [blockerId], references: [id])
  blocked User @relation("blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Report {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}
